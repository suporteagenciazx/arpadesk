# Template VPS — copie para .env na VPS (staging ou produção)
# cp .env.vps.example .env && nano .env && chmod 600 .env
#
# Deploy passo a passo: docs/03-deploy-vps.md
# Migração de dados do PC: docs/07-migracao-local-vps.md
# Referência completa: docs/05-variaveis-ambiente.md

ENVIRONMENT=production
DOMAIN=arpadesk-staging.seudominio.com.br

POSTGRES_USER=arpadesk
POSTGRES_PASSWORD=GERAR_openssl_rand_-base64_24
POSTGRES_DB=arpadesk_staging
DATABASE_URL=postgresql+psycopg2://arpadesk:SENHA_ACIMA@postgres:5432/arpadesk_staging

JWT_SECRET_KEY=GERAR_openssl_rand_-hex_32
JWT_EXPIRES_MINUTES=480

# OBRIGATÓRIO copiar do .env local se migrou cofre Suporte
VAULT_MASTER_KEY=COPIAR_DO_PC_OU_GERAR_NOVA

CORS_ORIGINS=https://arpadesk-staging.seudominio.com.br

UPLOAD_DIR=/data/uploads

# Recomendado: mesmas credenciais do local na 1ª migração (volume MinIO restaurado)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=arpadesk
S3_SECRET_KEY=arpadesksecret
S3_BUCKET=arpadesk
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PRESIGN_EXPIRES=3600
S3_PUBLIC_ENDPOINT=

REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=120

# Ignorado se banco já restaurado do dump local
SEEDED_ADMIN_EMAIL=admin@arpadesk.local
SEEDED_ADMIN_PASSWORD=TROCAR_SE_USAR_SEED
SEEDED_ADMIN_NAME=Administrador
